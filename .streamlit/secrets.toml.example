# Copy into Streamlit Community Cloud → App settings → Secrets
# (TOML format). Never commit real values.

APP_PASSWORD = "pick-a-team-password"
EODHD_API_KEY = "your-eodhd-key"
TUSHARE_TOKEN = "your-tushare-token"

# Personal access token (classic) with `repo` scope, or fine-grained token with
# Contents: Read and write + Actions: Read and write on this repository.
# Used so web edits (baskets / charts) and "Update all data now" persist.
GITHUB_TOKEN = "ghp_..."
GITHUB_REPO = "AmberYZ/BaiguanPro_basket_dashboard"
GITHUB_BRANCH = "main"
