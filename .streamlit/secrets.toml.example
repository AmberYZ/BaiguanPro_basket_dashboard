# Copy into Streamlit Community Cloud → App settings → Secrets
# (TOML format). Never commit real values.
#
# Paste tokens carefully:
# - Use double quotes around the value
# - No spaces, no line breaks inside the token
# - Do NOT wrap with extra quotes like "\"ghp_...\""

APP_PASSWORD = "pick-a-team-password"
EODHD_API_KEY = "your-eodhd-key"
TUSHARE_TOKEN = "your-tushare-token"

# Fine-grained PAT recommended:
#   Repository access → only this repo
#   Permissions → Contents: Read and write, Actions: Read and write
# Classic PAT alternative: scope `repo` (+ `workflow` if Update button fails)
GITHUB_TOKEN = "github_pat_..."
GITHUB_REPO = "AmberYZ/BaiguanPro_basket_dashboard"
GITHUB_BRANCH = "main"
